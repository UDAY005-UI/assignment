{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "sourceMap": true,
    "declaration": true,
    "rootDir": "./src",
    "types": ["node"]
  },
  "include": ["src/*.ts", "src/prisma.config.ts"],
  "exclude": ["dist", "node_modules"]
}
