{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2023",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "sourceMap": true,
    "declaration": true,
    "rootDir": "./src",
    "types": ["node"]
  },
  "include": ["src/*.ts"],
  "exclude": ["dist", "node_modules"]
}
